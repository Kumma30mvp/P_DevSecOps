        <mxCell id="client" value="Cliente HTTP&#10;(usuario / atacante)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=12;" vertex="1" parent="1">
