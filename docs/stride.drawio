        <mxCell id="memory" value="Almacenamiento&#10;EN MEMORIA&#10;(lista Python, sin BD)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
