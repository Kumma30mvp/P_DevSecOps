        <!-- ================= GITHUB / CI-CD ================= -->
        <mxCell id="repo" value="Repositorio GitHub&#10;(codigo + workflow)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="360" y="150" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pipeline" value="GitHub Actions Pipeline (CI/CD)&#10;1 Validate - 2 Build - 3 Gitleaks&#10;4 Trivy FS - 5 Semgrep&#10;6 Trivy Image - 7 OWASP ZAP&#10;8 Test - 9 Security Summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="540" y="140" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="image" value="Imagen Docker&#10;devsecops-api:latest&#10;(artifact image.tar)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="300" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reports" value="Reportes / Artifacts&#10;gitleaks, trivy-fs, semgrep,&#10;trivy-image, zap, summary" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="200" height="90" as="geometry" />
