        <!-- ================= TITULO ================= -->
        <mxCell id="title" value="Modelo de amenazas STRIDE - API DevSecOps (FastAPI + Docker + GitHub Actions + DefectDojo)&#10;Arquitectura REAL: almacenamiento en memoria (sin base de datos). PostgreSQL = arquitectura objetivo para produccion (fuera del MVP)." style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=14;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="50" as="geometry" />
        </mxCell>

        <!-- ================= TRUST BOUNDARIES ================= -->
        <mxCell id="tb_client" value="Frontera de confianza: Cliente / Internet (NO confiable)" style="rounded=1;dashed=1;dashPattern=8 8;strokeColor=#B85450;fillColor=none;verticalAlign=top;fontColor=#B85450;fontStyle=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="240" height="620" as="geometry" />
        </mxCell>
