          <mxGeometry x="1310" y="310" width="60" height="80" as="geometry" />
        </mxCell>

        <!-- ================= FLUJOS DE DATOS (con etiquetas STRIDE) ================= -->
        <mxCell id="f_dev_repo" value="git push / PR&#10;[S, T, R]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#B85450;" edge="1" parent="1" source="dev" target="repo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_repo_pipe" value="trigger push/PR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#6c8ebf;" edge="1" parent="1" source="repo" target="pipeline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_pipe_img" value="docker build" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#6c8ebf;" edge="1" parent="1" source="pipeline" target="image">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_pipe_reports" value="genera reportes&#10;[T, I]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#d6b656;" edge="1" parent="1" source="pipeline" target="reports">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_reports_ddojo" value="import scan results&#10;[T, I]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#9673a6;" edge="1" parent="1" source="reports" target="ddojo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_ddojo_analyst" value="revisa / prioriza" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#9673a6;" edge="1" parent="1" source="ddojo" target="analyst">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_client_api" value="HTTP requests&#10;[S, T, I, D]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#B85450;fontStyle=1;" edge="1" parent="1" source="client" target="fastapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_api_mem" value="lee / escribe items&#10;[T, R, I]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#82b366;" edge="1" parent="1" source="fastapi" target="memory">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_img_api" value="docker run" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;strokeColor=#82b366;" edge="1" parent="1" source="image" target="fastapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f_zap_api" value="OWASP ZAP DAST&#10;escaneo dinamico" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;dashed=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="pipeline" target="fastapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= LEYENDA STRIDE ================= -->
        <mxCell id="legend" value="LEYENDA STRIDE&#10;S = Spoofing (suplantacion)&#10;T = Tampering (manipulacion)&#10;R = Repudiation (repudio)&#10;I = Information Disclosure (fuga de info)&#10;D = Denial of Service (denegacion)&#10;E = Elevation of Privilege (elevacion)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="300" height="150" as="geometry" />
        </mxCell>

        <!-- ================= TABLA DE AMENAZAS Y MITIGACIONES ================= -->
        <mxCell id="threats" value="AMENAZAS PRINCIPALES Y MITIGACIONES&#10;&#10;1) FastAPI /admin/status  [I, E]  - Broken Access Control (OWASP A01).&#10;   Mitigacion (objetivo): autenticacion/autorizacion. HALLAZGO ACADEMICO INTENCIONAL.&#10;&#10;2) Cliente -&gt; FastAPI  [S, T, I, D]  - sin auth, input no confiable, sin rate-limit.&#10;   Mitigacion: validacion Pydantic (T) + cabeceras de seguridad (I) [IMPLEMENTADO];&#10;   auth + rate-limit (objetivo).&#10;&#10;3) FastAPI -&gt; Memoria  [T, R, I]  - datos volatiles, sin logging de auditoria.&#10;   Mitigacion: logging/auditoria y persistencia (objetivo: PostgreSQL en produccion).&#10;&#10;4) Dev -&gt; Repo  [S, T, R]  - commits no firmados, identidad suplantable.&#10;   Mitigacion: commits firmados, branch protection, revision de PR.&#10;&#10;5) Imagen Docker  [T, I]  - CVEs del SO base y dependencias.&#10;   Mitigacion: usuario no-root + apt upgrade + Trivy image [IMPLEMENTADO].&#10;&#10;6) Reportes -&gt; DefectDojo  [T, I]  - manipulacion/fuga de evidencia.&#10;   Mitigacion: artifacts con retencion, canal e importacion controlados." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#666666;fontSize=11;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="470" width="660" height="450" as="geometry" />
        </mxCell>

        <!-- Nota Gitleaks/SAST/SCA controles -->
        <mxCell id="controls" value="CONTROLES DEVSECOPS (shift-left) sobre el flujo:&#10;Gitleaks (secretos) . Semgrep (SAST) . Trivy FS (SCA) .&#10;Trivy Image (contenedor) . OWASP ZAP (DAST) . pytest (tests)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="360" y="400" width="440" height="70" as="geometry" />
        </mxCell>
      </root>
