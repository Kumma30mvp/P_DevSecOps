          <mxGeometry x="320" y="100" width="560" height="380" as="geometry" />
        </mxCell>
        <mxCell id="tb_runtime" value="Frontera de confianza: Runtime del contenedor (Docker host)" style="rounded=1;dashed=1;dashPattern=8 8;strokeColor=#82B366;fillColor=none;verticalAlign=top;fontColor=#82B366;fontStyle=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="520" width="560" height="220" as="geometry" />
        </mxCell>
